#Server Configuration
PORT=3000
NODE_ENV=production

# Admin Configuration
ADMIN_PASSWORD=your_admin_password_here

# MongoDB Database
# Production: MongoDB Atlas connection string (Atlas > Connect > Drivers)
# MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mkulima?retryWrites=true&w=majority
# Local development (requires MongoDB running locally):
# MONGODB_URL=mongodb://localhost:27017/mkulima
MONGODB_URL=

# Session Secret
SESSION_SECRET=your_session_secret_here

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Email Configuration (Nodemailer)
EMAIL_HOST=your_email_host
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_TO=your_email@example.com